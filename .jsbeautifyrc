{
  "html": {
    "indent_size": 2,
    "indent_char": " ",
    "max_preserve_newlines": 1,
    "preserve_newlines": true,
    "indent_inner_html": true,
    "wrap_line_length": 0,
    "end_with_newline": true,
    "indent_scripts": "keep",
    "extra_liners": []
  },
  "css": {
    "indent_size": 2,
    "indent_char": " ",
    "end_with_newline": true
  },
  "js": {
    "indent_size": 2,
    "indent_char": " ",
    "end_with_newline": true,
    "jslint_happy": false,
    "preserve_newlines": true,
    "max_preserve_newlines": 2
  }
}
